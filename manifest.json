{
  "manifest_version": 3,
  "name": "Kick Deleted Messages",
  "version": "1.0.0",
  "description": "Shows messages deleted by moderation on Kick.com",
  "permissions": ["storage"],
  "host_permissions": ["https://kick.com/*"],
  "action": {
    "default_title": "Kick Deleted Messages",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://kick.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
